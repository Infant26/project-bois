# ============================================================
# SUPABASE CONFIGURATION
# ============================================================
# Get these from Supabase Project Settings > API > Project Settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only - NEVER expose this in browser, Vercel only!
# Get from Supabase > Settings > API > Service Role Secret
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================
# RAZORPAY CONFIGURATION (optional)
# ============================================================
# Set NEXT_PUBLIC_ENABLE_RAZORPAY=false for "Pay at Property" mode
NEXT_PUBLIC_ENABLE_RAZORPAY=false

# Only needed if NEXT_PUBLIC_ENABLE_RAZORPAY=true
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ============================================================
# EMAILJS CONFIGURATION (optional - for booking emails)
# ============================================================
# Get these from emailjs.com dashboard
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
NEXT_PUBLIC_OWNER_EMAIL=owner@example.com

# ============================================================
# PROPERTY CONFIGURATION
# ============================================================
NEXT_PUBLIC_PROPERTY_NAME=The Coastal Calm
NEXT_PUBLIC_PROPERTY_LOCATION=Pondicherry, India
